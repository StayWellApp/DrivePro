// packages/database/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  firstName   String?
  lastName    String?
  phoneNumber String?
  role        Role
  school_id   String?
  school      School?  @relation(fields: [school_id], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student    Student?
  instructor Instructor?
}

model School {
  id                String   @id @default(uuid())
  name              String
  stripe_account_id String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users       User[]
  students    Student[]
  instructors Instructor[]
  vehicles    Vehicle[]
  lessons     Lesson[]
  payments    Payment[]
}

model Student {
  id                 String   @id @default(uuid())
  user_id            String   @unique
  user               User     @relation(fields: [user_id], references: [id])
  instructor_id      String?
  instructor         Instructor? @relation(fields: [instructor_id], references: [id])
  school_id          String
  school             School   @relation(fields: [school_id], references: [id])
  name               String?
  balance            Float    @default(0)
  lessonCredits      Int      @default(0)
  courseType         CourseType
  stripe_customer_id String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lessons       Lesson[]
  payments      Payment[]
  theoryResults TheoryResult[]
  documents     Document[]
}

enum CourseType {
  A
  B
  C
}

model Instructor {
  id           String   @id @default(uuid())
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [id])
  school_id    String
  school       School   @relation(fields: [school_id], references: [id])
  name         String?
  availability Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students Student[]
  lessons  Lesson[]
}

model Vehicle {
  id                 String    @id @default(uuid())
  school_id          String
  school             School    @relation(fields: [school_id], references: [id])
  licensePlate       String
  vin                String?
  make               String
  model              String
  lastServiceDate    DateTime?
  nextServiceDate    DateTime?
  nextServiceMileage Int?
  insuranceExpiry    DateTime?
  nextTechnicalInspection DateTime?
  current_mileage    Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lessons Lesson[]
}

model Lesson {
  id            String   @id @default(uuid())
  school_id     String
  school        School   @relation(fields: [school_id], references: [id])
  student_id    String
  student       Student  @relation(fields: [student_id], references: [id])
  instructor_id String
  instructor    Instructor @relation(fields: [instructor_id], references: [id])
  vehicle_id    String
  vehicle       Vehicle  @relation(fields: [vehicle_id], references: [id])
  startTime     DateTime
  endTime       DateTime?
  videoTimestampOffset Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions LessonSession[]
  telemetryChunks TelemetryChunk[]
}

model LessonSession {
  id                 String    @id @default(uuid())
  school_id          String
  lesson_id          String
  lesson             Lesson    @relation(fields: [lesson_id], references: [id])
  video_file_name    String?
  dashcam_start_time DateTime?
  gps_route          Unsupported("geography(LineString, 4326)")?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  faultPins FaultPin[]
}

model FaultPin {
  id                   String   @id @default(uuid())
  school_id            String
  lesson_session_id    String
  lessonSession        LessonSession @relation(fields: [lesson_session_id], references: [id])
  category             String
  latitude             Float
  longitude            Float
  timestamp            DateTime
  notes                String?
  riskScore            Float?
  video_file_name      String?
  video_offset_seconds Int?
  createdAt            DateTime @default(now())
}

model Payment {
  id         String   @id @default(uuid())
  school_id  String
  school     School   @relation(fields: [school_id], references: [id])
  student_id String
  student    Student  @relation(fields: [student_id], references: [id])
  amount     Float
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TheoryQuestion {
  id        String   @id @default(uuid())
  question  String
  options   Json
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TheoryResult {
  id         String   @id @default(uuid())
  student_id String
  student    Student  @relation(fields: [student_id], references: [id])
  score      Int
  total      Int
  mode       String // 'practice' or 'mock'
  createdAt  DateTime @default(now())
}

model TelemetryChunk {
  id          String   @id @default(uuid())
  lesson_id   String
  lesson      Lesson   @relation(fields: [lesson_id], references: [id])
  coordinates Json
  faults      Json
  createdAt   DateTime @default(now())
}

model Document {
  id          String   @id @default(uuid())
  student_id  String
  student     Student  @relation(fields: [student_id], references: [id])
  type        DocumentType
  fileUrl     String
  expiryDate  DateTime?
  status      DocumentStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum DocumentType {
  ID_CARD
  MEDICAL_CERTIFICATE
  DRIVERS_LICENSE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}
