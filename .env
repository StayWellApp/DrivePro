# DrivePro Environment Variables Template
# Copy this to .env or use it as a reference for Cloud Run environment variables.

# --- Database ---
# The connection string for the PostgreSQL database (Cloud SQL with PostGIS).
# When running in Cloud Run, use the Unix socket path:
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASS>@localhost/<DB_NAME>?host=/cloudsql/drivepro-production:europe-west4:drivepro-db-main"
#
# For local development with Cloud SQL Auth Proxy, it will look like this:
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASS>@localhost:5432/<DB_NAME>"
DATABASE_URL=postgresql://postgres:ZfrF4g6h43rfR4566F@localhost:5432/drivepro_local?schema=public
# --- Application Configuration ---
# The port the application will run on (Cloud Run provides this dynamically).
PORT="3000"

# --- Next.js Internationalization ---
NEXT_PUBLIC_DEFAULT_LOCALE="cs"
